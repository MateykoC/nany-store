# ════════════════════════════════════
# NANY Store — Variables de entorno
# ════════════════════════════════════

# URL de conexión a PostgreSQL (Render te la da automáticamente si usas su DB)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# Contraseña del panel admin (podés cambiarla acá)
ADMIN_PASSWORD=1234

# Número de WhatsApp en formato internacional sin + ni espacios
# Ejemplo Argentina: 5491112345678
WHATSAPP_NUMBER=5491100000000

# Entorno (en Render setear como "production")
NODE_ENV=production
